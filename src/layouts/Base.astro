---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Tipo test, V/F y flashcards para la carrera. Gratis.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — repasaYA</title>
  <link rel="icon" type="image/png" href={`${base}logo.png`} />
  <meta property="og:title" content={`${title} — repasaYA`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://jxliian.github.io/repasaYA/logo.png" />
  <meta property="og:type" content="website" />
  <style>
    :root {
      --bg:#0f1117; --surface:#1a1d27; --surface2:#252836; --border:#2e3347;
      --accent:#6c63ff; --accent2:#a78bfa; --accent-hover:#574fd6;
      --correct:#22c55e; --wrong:#ef4444; --reveal:#f59e0b;
      --text:#e2e8f0; --text-muted:#7c8db5; --radius:12px;
    }
    * { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:'Segoe UI',system-ui,sans-serif; background:var(--bg); color:var(--text); min-height:100vh; }
    a { color:inherit; text-decoration:none; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
