---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const GH = 'https://github.com/jxliian/repasaYA/blob/main/tipo-test/AEF';
---
<Base title="Análisis de Estados Financieros" description="38 preguntas tipo test, 63 flashcards y recursos de Análisis de Estados Financieros (AEF). Casos reales: Dulcesol, Viscofan, Mercadona y más.">
<style is:global>
  html,body{height:100%;overflow:hidden}
  header{background:var(--surface);border-bottom:1px solid var(--border);padding:14px 24px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
  .logo{font-size:1.15rem;font-weight:800}.logo span{color:var(--accent)}
  .back{font-size:.8rem;color:var(--text-muted);transition:color .2s}.back:hover{color:var(--accent)}
  main{flex:1;min-height:0;overflow-y:auto;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px 24px;gap:32px}
  .hub-hero{text-align:center;display:flex;flex-direction:column;align-items:center;gap:12px}
  .hub-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(108,99,255,.12);border:1px solid rgba(108,99,255,.3);border-radius:99px;padding:5px 14px;font-size:.75rem;color:var(--accent2);font-weight:600}
  .hub-title{font-size:clamp(1.6rem,3vw,2.4rem);font-weight:800;letter-spacing:-1px}
  .hub-title span{background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .hub-desc{font-size:.9rem;color:var(--text-muted);max-width:520px;line-height:1.6}
  .hub-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;width:100%;max-width:900px}
  .hub-card{background:var(--surface);border:2px solid var(--border);border-radius:var(--radius);padding:28px 22px;display:flex;flex-direction:column;gap:14px;transition:all .22s;position:relative;overflow:hidden;text-decoration:none;color:var(--text)}
  .hub-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--accent),var(--accent2));opacity:0;transition:opacity .22s}
  .hub-card:hover{border-color:var(--accent);background:#1e1c35;transform:translateY(-4px);box-shadow:0 12px 32px rgba(108,99,255,.2)}
  .hub-card:hover::before{opacity:1}
  .hub-card-icon{font-size:2rem;width:52px;height:52px;border-radius:12px;background:rgba(108,99,255,.1);border:1px solid rgba(108,99,255,.2);display:flex;align-items:center;justify-content:center}
  .hub-card-title{font-size:1.05rem;font-weight:800}
  .hub-card-desc{font-size:.8rem;color:var(--text-muted);line-height:1.55;flex:1}
  .hub-card-chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:auto}
  .hub-chip{font-size:.68rem;font-weight:600;background:rgba(108,99,255,.1);border:1px solid rgba(108,99,255,.2);border-radius:99px;padding:3px 10px;color:var(--accent2)}
  .hub-card-arrow{position:absolute;bottom:20px;right:20px;font-size:.9rem;color:var(--accent);opacity:0;transform:translateX(-4px);transition:all .2s}
  .hub-card:hover .hub-card-arrow{opacity:1;transform:translateX(0)}
  .gh-card .hub-card-icon{background:rgba(148,163,184,.08);border-color:rgba(148,163,184,.2)}
  .gh-card:hover{border-color:#94a3b8;box-shadow:0 12px 32px rgba(148,163,184,.1)}
  .gh-card::before{background:linear-gradient(90deg,#475569,#94a3b8)}
  .gh-card .hub-chip{background:rgba(148,163,184,.08);border-color:rgba(148,163,184,.2);color:#94a3b8}
  .gh-card .hub-card-arrow{color:#94a3b8}
  body{display:flex;flex-direction:column}
  @media(max-width:700px){html,body{height:auto;overflow:visible}main{overflow:visible}.hub-cards{grid-template-columns:1fr}}
</style>

<header>
  <div style="display:flex;align-items:center;gap:12px">
    <a class="back" href={base}>← repasaYA</a>
    <span style="color:var(--border)">|</span>
    <div class="logo"><span>AEF</span> · Análisis de Estados Financieros</div>
  </div>
  <div style="font-size:.75rem;color:var(--text-muted)">ADE · Finanzas</div>
</header>

<main>
  <div class="hub-hero">
    <span class="hub-badge">📈 ADE · Finanzas</span>
    <h1 class="hub-title">Análisis de <span>Estados Financieros</span></h1>
    <p class="hub-desc">Tipo test con casos reales, flashcards de ratios y recursos de estudio. Casos: Dulcesol, Viscofan, Mercadona, Primor, INDESPA y más.</p>
  </div>

  <div class="hub-cards">
    <a class="hub-card" href={`${base}aef/quiz/`}>
      <div class="hub-card-icon">🧠</div>
      <div class="hub-card-title">Tipo Test</div>
      <p class="hub-card-desc">38 preguntas de opción múltiple con casos reales de empresas cotizadas. FM, NOF, PMM, ratios y apalancamiento.</p>
      <div class="hub-card-chips">
        <span class="hub-chip">38 preguntas</span>
        <span class="hub-chip">Casos reales</span>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>

    <a class="hub-card" href={`${base}aef/glosario/`}>
      <div class="hub-card-icon">🃏</div>
      <div class="hub-card-title">Flashcards</div>
      <p class="hub-card-desc">63 tarjetas con fórmulas e interpretación de ratios: endeudamiento, solvencia, rentabilidad, NOF, PMM y EFE.</p>
      <div class="hub-card-chips">
        <span class="hub-chip">63 tarjetas</span>
        <span class="hub-chip">11 temas</span>
        <span class="hub-chip">Flashcards</span>
      </div>
      <span class="hub-card-arrow">→</span>
    </a>

    <a class="hub-card gh-card" href={`${GH}/ANALISIS_EXAMENES.md`} target="_blank" rel="noopener">
      <div class="hub-card-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" style="color:#94a3b8"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      </div>
      <div class="hub-card-title">Análisis de Exámenes</div>
      <p class="hub-card-desc">Análisis exhaustivo de 13 casos reales de exámenes ordinarios. Patrones, errores frecuentes y claves para cada tipo de pregunta.</p>
      <div class="hub-card-chips">
        <span class="hub-chip">13 casos</span>
        <span class="hub-chip">GitHub ↗</span>
      </div>
      <span class="hub-card-arrow">↗</span>
    </a>

    <a class="hub-card gh-card" href={`${GH}/DUDAS_RESUELTAS.md`} target="_blank" rel="noopener">
      <div class="hub-card-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" style="color:#94a3b8"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      </div>
      <div class="hub-card-title">Dudas Resueltas</div>
      <p class="hub-card-desc">Preguntas frecuentes y dudas conceptuales resueltas sobre ratios, interpretación de estados financieros y casos prácticos.</p>
      <div class="hub-card-chips">
        <span class="hub-chip">Conceptual</span>
        <span class="hub-chip">GitHub ↗</span>
      </div>
      <span class="hub-card-arrow">↗</span>
    </a>

    <a class="hub-card gh-card" href={`${GH}/EXAMEN_SIMULACRO.md`} target="_blank" rel="noopener">
      <div class="hub-card-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" style="color:#94a3b8"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
      </div>
      <div class="hub-card-title">Examen Simulacro</div>
      <p class="hub-card-desc">Examen completo de simulacro con la empresa IBERFRUT, S.A. (ejercicio 2024). Estructura real de examen ordinario.</p>
      <div class="hub-card-chips">
        <span class="hub-chip">IBERFRUT 2024</span>
        <span class="hub-chip">GitHub ↗</span>
      </div>
      <span class="hub-card-arrow">↗</span>
    </a>
  </div>
</main>
</Base>
