---
import Base from '../../layouts/Base.astro';
import flashcardData from '../../data/aef-flashcards.json';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const totalTerms = flashcardData.length;
---
<Base title="AEF · Flashcards" description="63 flashcards de Análisis de Estados Financieros: ratios, PMM, NOF, FM, EFE y rentabilidad.">
<style is:global>
  html,body{height:100%;overflow:hidden}
  header{background:var(--surface);border-bottom:1px solid var(--border);padding:14px 24px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
  .logo{font-size:1.15rem;font-weight:800}.logo span{color:var(--accent)}
  .back{font-size:.8rem;color:var(--text-muted);transition:color .2s}.back:hover{color:var(--accent)}
  .tabs{display:flex;background:var(--surface);border-bottom:1px solid var(--border)}
  .tab{padding:12px 20px;cursor:pointer;font-size:.9rem;color:var(--text-muted);border-bottom:2px solid transparent;transition:all .2s;user-select:none}
  .tab.active{color:var(--accent);border-bottom-color:var(--accent)}.tab:hover:not(.active){color:var(--text)}
  main{flex:1;min-height:0;overflow-y:auto;padding:24px;max-width:860px;width:100%;margin:0 auto}
  .panel{display:none;flex-direction:column;gap:20px}.panel.active{display:flex}
  .start{display:flex;flex-direction:column;gap:24px;padding:8px 0}
  .sel-label{font-size:.72rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.8px;display:block;margin-bottom:8px}
  .btn-start{width:100%;padding:16px;font-size:1rem;border-radius:var(--radius);background:var(--accent);color:#fff;border:none;font-weight:800;cursor:pointer;transition:all .2s}
  .btn-start:hover{background:var(--accent-hover);box-shadow:0 4px 20px rgba(108,99,255,.4);transform:translateY(-1px)}
  .tema-chips{display:flex;flex-wrap:wrap;gap:8px}
  .tema-chip{padding:6px 14px;border:1.5px solid var(--border);border-radius:99px;background:var(--surface2);color:var(--text-muted);font-size:.78rem;font-weight:600;cursor:pointer;transition:all .18s;user-select:none;line-height:1.5}
  .tema-chip:hover{border-color:var(--accent);color:var(--accent2)}
  .tema-chip.chip-on{border-color:var(--accent);background:rgba(108,99,255,.14);color:var(--accent2)}
  .chip-all.chip-on{background:var(--accent);color:#fff}
  .chip-count{font-size:.65rem;opacity:.7;margin-left:4px}
  .q-header{display:flex;justify-content:space-between;align-items:center;font-size:.8rem;color:var(--text-muted)}
  .progress-bar{height:4px;background:var(--surface2);border-radius:99px;overflow:hidden;margin-top:6px}
  .progress-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:99px;transition:width .3s}
  .flip-wrap{perspective:1200px;cursor:pointer;margin-top:16px;min-height:240px}
  .flip-inner{position:relative;width:100%;min-height:240px;transform-style:preserve-3d;transition:transform .5s cubic-bezier(.4,0,.2,1)}
  .flip-inner.flipped{transform:rotateY(180deg)}
  .flip-face{position:absolute;inset:0;backface-visibility:hidden;-webkit-backface-visibility:hidden;border-radius:var(--radius);display:flex;flex-direction:column;justify-content:center;align-items:center;padding:32px 28px;text-align:center;border:1px solid var(--border)}
  .flip-front{background:var(--surface)}
  .flip-back{background:var(--surface2);transform:rotateY(180deg);text-align:left;align-items:flex-start;justify-content:flex-start;padding:28px}
  .flip-tema{font-size:.68rem;font-weight:700;color:var(--accent);text-transform:uppercase;letter-spacing:.8px;margin-bottom:16px}
  .flip-term{font-size:1.3rem;font-weight:800;letter-spacing:-.5px;color:var(--text);margin-bottom:20px}
  .flip-hint{font-size:.75rem;color:var(--text-muted);display:flex;align-items:center;gap:6px}
  .flip-back-label{font-size:.68rem;font-weight:700;color:var(--accent2);text-transform:uppercase;letter-spacing:.8px;margin-bottom:10px}
  .flip-def{font-size:.88rem;line-height:1.7;color:var(--text)}
  .q-nav{display:flex;justify-content:flex-end;gap:10px;margin-top:16px}
  .btn{padding:11px 22px;border:none;border-radius:var(--radius);font-size:.88rem;font-weight:700;cursor:pointer;transition:all .2s}
  .btn-primary{background:var(--accent);color:#fff}.btn-primary:hover{background:var(--accent-hover)}
  .btn-ghost{background:var(--surface2);color:var(--text);border:1px solid var(--border)}.btn-ghost:hover{border-color:var(--accent);color:var(--accent)}
  .stats-box{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px}
  .stats-row{display:flex;justify-content:space-around;gap:12px;flex-wrap:wrap}
  .stat-item{text-align:center}.stat-num{font-size:2.2rem;font-weight:800;letter-spacing:-1px;color:var(--accent2)}
  .stat-lbl{font-size:.75rem;color:var(--text-muted);margin-top:2px}
  .controls{display:flex;gap:10px;flex-wrap:wrap}
  .search-box{flex:1;min-width:180px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:10px 14px;color:var(--text);font-size:.9rem;outline:none;transition:border-color .2s}
  .search-box:focus{border-color:var(--accent)}.search-box::placeholder{color:var(--text-muted)}
  .cnt{font-size:.78rem;color:var(--text-muted)}
  .bank-list{display:flex;flex-direction:column;gap:10px}
  .bank-item{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px 18px;display:flex;gap:14px;flex-direction:column}
  .bank-meta{font-size:.68rem;font-weight:700;color:var(--accent);text-transform:uppercase;letter-spacing:.5px}
  .bank-term{font-size:.95rem;font-weight:700;color:var(--text);margin-bottom:4px}
  .bank-def{font-size:.84rem;color:var(--text-muted);line-height:1.6}
  body{display:flex;flex-direction:column}
  @media(max-width:560px){html,body{height:auto;overflow:visible}main{overflow:visible;padding-bottom:80px}}
</style>

<header>
  <div style="display:flex;align-items:center;gap:12px">
    <a class="back" href={`${base}aef/`}>← AEF</a>
    <span style="color:var(--border)">|</span>
    <div class="logo"><span>AEF</span> · Flashcards</div>
  </div>
  <div style="font-size:.78rem;color:var(--text-muted)">{totalTerms} términos</div>
</header>

<div class="tabs">
  <div class="tab active" data-tab="flashcards">Flashcards</div>
  <div class="tab" data-tab="banco">Todos los términos</div>
</div>

<main style="display:flex;flex-direction:column;flex:1">
  <div id="panel-flashcards" class="panel active">
    <div id="selector-view" class="start">
      <div>
        <span class="sel-label">Tema <span id="sel-count" style="font-weight:400;text-transform:none;letter-spacing:0"></span></span>
        <div class="tema-chips" id="tema-chips"></div>
      </div>
      <button class="btn-start" id="btn-start">Empezar →</button>
    </div>

    <div id="card-view" style="display:none;flex-direction:column;gap:0">
      <div class="q-header">
        <span id="card-counter"></span>
        <span style="font-size:.75rem;color:var(--text-muted)">Toca la tarjeta para ver la definición</span>
      </div>
      <div class="progress-bar"><div class="progress-fill" id="card-progress" style="width:0%"></div></div>
      <div class="flip-wrap" id="flip-wrap">
        <div class="flip-inner" id="flip-inner">
          <div class="flip-face flip-front">
            <div class="flip-tema" id="card-tema"></div>
            <div class="flip-term" id="card-term"></div>
            <div class="flip-hint">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>
              Toca para ver la definición
            </div>
          </div>
          <div class="flip-face flip-back">
            <div class="flip-back-label">Definición</div>
            <div class="flip-def" id="card-def"></div>
          </div>
        </div>
      </div>
      <div class="q-nav">
        <button class="btn btn-ghost" id="btn-back-sel">← Volver</button>
        <button class="btn btn-ghost" id="btn-prev" style="display:none">← Anterior</button>
        <button class="btn btn-primary" id="btn-next">Siguiente →</button>
      </div>
    </div>

    <div id="results-view" style="display:none;flex-direction:column;gap:20px">
      <div class="stats-box">
        <div style="font-size:1.1rem;font-weight:800;margin-bottom:20px">Repaso completado</div>
        <div class="stats-row">
          <div class="stat-item"><div class="stat-num" id="r-total"></div><div class="stat-lbl">Términos repasados</div></div>
          <div class="stat-item"><div class="stat-num" id="r-temas"></div><div class="stat-lbl">Temas cubiertos</div></div>
        </div>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn btn-primary" id="btn-repeat">Repetir</button>
        <button class="btn btn-ghost" id="btn-back-sel2">← Volver</button>
      </div>
    </div>
  </div>

  <div id="panel-banco" class="panel">
    <div class="controls">
      <input class="search-box" type="text" id="b-search" placeholder="Buscar término...">
      <select class="search-box" id="b-tema" style="max-width:240px">
        <option value="">Todos los temas</option>
      </select>
    </div>
    <div class="cnt" id="b-count"></div>
    <div class="bank-list" id="b-list"></div>
  </div>
</main>

<script define:vars={{ glosario: flashcardData }}>
const TERMS = glosario;
const TEMAS = [...new Set(TERMS.map(t => t.tema))];
let filtered = [], idx = 0, flipped = false;
let selectedTemas = new Set();

function renderChips() {
  const container = document.getElementById('tema-chips');
  container.innerHTML = '';
  const allChip = document.createElement('button');
  allChip.className = 'tema-chip chip-all' + (selectedTemas.size === 0 ? ' chip-on' : '');
  allChip.innerHTML = 'Todos<span class="chip-count">' + TERMS.length + '</span>';
  allChip.addEventListener('click', () => { selectedTemas.clear(); renderChips(); });
  container.appendChild(allChip);
  TEMAS.forEach(t => {
    const count = TERMS.filter(x => x.tema === t).length;
    const chip = document.createElement('button');
    chip.className = 'tema-chip' + (selectedTemas.has(t) ? ' chip-on' : '');
    chip.innerHTML = t + '<span class="chip-count">' + count + '</span>';
    chip.addEventListener('click', () => {
      if (selectedTemas.has(t)) selectedTemas.delete(t); else selectedTemas.add(t);
      renderChips();
    });
    container.appendChild(chip);
  });
  const countEl = document.getElementById('sel-count');
  if (countEl) countEl.textContent = selectedTemas.size === 0 ? '' : '· ' + selectedTemas.size + ' de ' + TEMAS.length + ' seleccionados';
}

function shuffle(a) { return [...a].sort(() => Math.random() - .5); }

function startSession() {
  const pool = selectedTemas.size === 0 ? TERMS : TERMS.filter(t => selectedTemas.has(t.tema));
  filtered = shuffle(pool);
  idx = 0; flipped = false;
  hide('selector-view'); hide('results-view');
  const cv = document.getElementById('card-view');
  cv.style.display = 'flex'; cv.style.flexDirection = 'column'; cv.style.gap = '0';
  showCard();
}

function showCard() {
  flipped = false;
  document.getElementById('flip-inner').classList.remove('flipped');
  const t = filtered[idx];
  document.getElementById('card-tema').textContent = t.tema;
  document.getElementById('card-term').textContent = t.term;
  document.getElementById('card-def').textContent = t.def;
  document.getElementById('card-counter').textContent = (idx + 1) + ' / ' + filtered.length;
  document.getElementById('card-progress').style.width = ((idx / filtered.length) * 100) + '%';
  idx > 0 ? showEl('btn-prev') : hideEl('btn-prev');
}

function toggleFlip() {
  flipped = !flipped;
  document.getElementById('flip-inner').classList.toggle('flipped', flipped);
}

function nextCard() { idx++; if (idx >= filtered.length) { showResults(); return; } showCard(); }
function prevCard() { if (idx > 0) { idx--; showCard(); } }

function showResults() {
  hide('card-view');
  const rv = document.getElementById('results-view');
  rv.style.display = 'flex'; rv.style.flexDirection = 'column'; rv.style.gap = '20px';
  document.getElementById('r-total').textContent = filtered.length;
  document.getElementById('r-temas').textContent = new Set(filtered.map(t => t.tema)).size;
}

function backToSelector() { hide('card-view'); hide('results-view'); document.getElementById('selector-view').style.display = ''; }
function show(id) { document.getElementById(id).style.display = ''; }
function hide(id) { document.getElementById(id).style.display = 'none'; }
function showEl(id) { document.getElementById(id).style.display = ''; }
function hideEl(id) { document.getElementById(id).style.display = 'none'; }

renderChips();
document.getElementById('btn-start').addEventListener('click', startSession);
document.getElementById('btn-next').addEventListener('click', nextCard);
document.getElementById('btn-prev').addEventListener('click', prevCard);
document.getElementById('btn-back-sel').addEventListener('click', backToSelector);
document.getElementById('btn-back-sel2').addEventListener('click', backToSelector);
document.getElementById('btn-repeat').addEventListener('click', startSession);
document.getElementById('flip-wrap').addEventListener('click', toggleFlip);

document.querySelectorAll('.tab').forEach(t => {
  t.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(x => x.classList.remove('active'));
    t.classList.add('active');
    document.getElementById('panel-' + t.dataset.tab).classList.add('active');
    if (t.dataset.tab === 'banco') initBank();
  });
});

let bankReady = false;
function initBank() {
  if (bankReady) return; bankReady = true;
  const sel = document.getElementById('b-tema');
  TEMAS.forEach(t => { const o = document.createElement('option'); o.value = t; o.textContent = t; sel.appendChild(o); });
  document.getElementById('b-search').addEventListener('input', filterBank);
  document.getElementById('b-tema').addEventListener('change', filterBank);
  filterBank();
}

function filterBank() {
  const s = document.getElementById('b-search').value.toLowerCase();
  const tema = document.getElementById('b-tema').value;
  const list = TERMS.filter(t => (!tema || t.tema === tema) && (!s || t.term.toLowerCase().includes(s) || t.def.toLowerCase().includes(s)));
  document.getElementById('b-count').textContent = list.length + ' términos';
  const el = document.getElementById('b-list'); el.innerHTML = '';
  list.forEach(t => {
    const div = document.createElement('div'); div.className = 'bank-item';
    div.innerHTML = '<div class="bank-meta">' + t.tema + '</div><div class="bank-term">' + t.term + '</div><div class="bank-def">' + t.def + '</div>';
    el.appendChild(div);
  });
}
</script>
</Base>
