---
import Base from '../../layouts/Base.astro';
import QuizEngine from '../../components/QuizEngine.astro';
import testData from '../../data/aef-test.json';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<Base title="AEF · Tipo Test" description="38 preguntas tipo test de Análisis de Estados Financieros con casos reales: Dulcesol, Viscofan, Mercadona, Primor e INDESPA.">
  <QuizEngine
    title="Análisis de Estados Financieros"
    code="AEF"
    testData={testData}
    backHref={`${base}aef/`}
    backLabel="Análisis de Estados Financieros"
  />
</Base>
