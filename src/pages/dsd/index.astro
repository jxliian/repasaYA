---
import Base from '../../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<Base title="Desarrollo de Sistemas Distribuidos" description="Resumen T4+T5 de Desarrollo de Sistemas Distribuidos en PDF. Temario completo para repasar.">
<style is:global>
  html{height:100%;overflow:hidden}
  body{height:100%;overflow:hidden;display:flex;flex-direction:column;min-height:0!important}
  header{background:var(--surface);border-bottom:1px solid var(--border);padding:14px 24px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;flex-shrink:0}
  .logo{font-size:1.15rem;font-weight:800}.logo span{color:var(--accent)}
  .back{font-size:.8rem;color:var(--text-muted);transition:color .2s}.back:hover{color:var(--accent)}
  main{flex:1;min-height:0;display:flex;flex-direction:column;overflow:hidden}
  .top-bar{padding:16px 24px;display:flex;align-items:center;justify-content:space-between;gap:12px;border-bottom:1px solid var(--border);flex-shrink:0}
  .doc-title{font-size:.95rem;font-weight:700;color:var(--text)}
  .doc-sub{font-size:.75rem;color:var(--text-muted);margin-top:2px}
  .btn-dl{display:inline-flex;align-items:center;gap:7px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);border-radius:99px;padding:8px 16px;color:#fca5a5;font-size:.78rem;font-weight:700;transition:all .2s;text-decoration:none;white-space:nowrap}
  .btn-dl:hover{background:rgba(239,68,68,.18);border-color:#ef4444}
  .iframe-wrap{flex:1;min-height:0;position:relative}
  .iframe-wrap iframe{position:absolute;inset:0;width:100%;height:100%;border:none}
  @media(max-width:700px){html,body{height:auto;overflow:visible;display:block}main{overflow:visible}.iframe-wrap{position:static;height:85vh}.iframe-wrap iframe{position:static;height:100%}}
</style>

<header>
  <div style="display:flex;align-items:center;gap:12px">
    <a class="back" href={base}>← repasaYA</a>
    <span style="color:var(--border)">|</span>
    <div class="logo"><span>DSD</span> · Sistemas Distribuidos</div>
  </div>
  <div style="font-size:.75rem;color:var(--text-muted)">Informática · DSD</div>
</header>

<main>
  <div class="top-bar">
    <div>
      <div class="doc-title">Resumen T4 + T5</div>
      <div class="doc-sub">Desarrollo de Sistemas Distribuidos</div>
    </div>
    <a class="btn-dl" href={`${base}dsd/ResumenDSD_T4_T5.pdf`} download>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      Descargar PDF
    </a>
  </div>
  <div class="iframe-wrap">
    <iframe src={`${base}dsd/ResumenDSD_T4_T5.pdf`} title="Resumen DSD T4+T5"></iframe>
  </div>
</main>
</Base>
