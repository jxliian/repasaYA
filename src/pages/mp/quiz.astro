---
import Base from '../../layouts/Base.astro';
import QuizEngine from '../../components/QuizEngine.astro';
import testData from '../../data/mp-test.json';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<Base title="MP · Tipo Test" description="67 preguntas tipo test de Metodología de la Programación con código C++. Punteros, clases, sobrecarga de operadores, ficheros y Fraud4.">
  <QuizEngine
    title="Metodología de la Programación"
    code="MP"
    testData={testData}
    backHref={`${base}mp/`}
    backLabel="Metodología de la Programación"
  />
</Base>
